# ==========================================
# Foxhole Agent Configuration
# ==========================================

# Core Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Redis Configuration (Required for Celery/Cache)
REDIS_URL=redis://localhost:6379/0

# LLM Provider Configuration
# Set the provider and key. Aliases (agent-primary, agent-local) are mapped in the code.
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-key
# OLLAMA_BASE_URL=http://localhost:11434

# ==========================================
# Modular Integrations (Opt-in)
# ==========================================

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Proxmox
PROXMOX_HOST=
PROXMOX_USER=homelab-agent@pve
PROXMOX_TOKEN_NAME=agent
PROXMOX_TOKEN_VALUE=

# Docker / Portainer
DOCKER_HOST=tcp://socket-proxy:2375
PORTAINER_URL=
PORTAINER_API_TOKEN=

# Media Server (Plex)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=

# Media Management (*Arr)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=
RADARR_URL=http://localhost:7878
RADARR_API_KEY=

# Observability
TAUTULLI_URL=http://localhost:8181
TAUTULLI_API_KEY=
OVERSEERR_URL=http://localhost:5055
OVERSEERR_API_KEY=

# Network (Pi-hole)
PIHOLE_URL=http://localhost/admin
PIHOLE_API_TOKEN=
ALLOWED_SCAN_SUBNETS=192.168.1.0/24
