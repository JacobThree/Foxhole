# Core API
FOXHOLE_ENVIRONMENT=development
FOXHOLE_API_BEARER_TOKEN=change-me
FOXHOLE_REDIS_URL=redis://localhost:6379/0

# LiteLLM provider aliases
FOXHOLE_LLM_PRIMARY_MODEL=agent-primary
FOXHOLE_LLM_PRIMARY_API_KEY=
FOXHOLE_LLM_PRIMARY_API_BASE=
FOXHOLE_LLM_LOCAL_MODEL=agent-local
FOXHOLE_LLM_LOCAL_API_BASE=http://localhost:11434
FOXHOLE_LLM_VLLM_MODEL=agent-vllm
FOXHOLE_LLM_VLLM_API_BASE=http://localhost:8001/v1
FOXHOLE_LLM_TIMEOUT_SECONDS=30
FOXHOLE_LLM_RETRIES=2

# Write-action policy. Stage 1 denies writes, stage 2 requires confirmation, stage 3 allows marked autonomous tools.
FOXHOLE_WRITE_STAGE=1
FOXHOLE_WRITE_CONFIRMATION_SECRET=

# Proxmox read-only token. See docs/deployment/proxmox-permissions.md.
FOXHOLE_PROXMOX_HOST=
FOXHOLE_PROXMOX_VERIFY_SSL=true
FOXHOLE_PROXMOX_TOKEN_ID=homelab-agent@pve!foxhole
FOXHOLE_PROXMOX_TOKEN_SECRET=

# Docker socket proxy
FOXHOLE_DOCKER_SOCKET_PROXY_URL=tcp://docker-socket-proxy:2375

# Telegram alerts
FOXHOLE_TELEGRAM_BOT_TOKEN=
FOXHOLE_TELEGRAM_CHAT_ID=

# Plex
FOXHOLE_PLEX_BASE_URL=
FOXHOLE_PLEX_TOKEN=

# Sonarr
FOXHOLE_SONARR_BASE_URL=
FOXHOLE_SONARR_API_KEY=

# Radarr
FOXHOLE_RADARR_BASE_URL=
FOXHOLE_RADARR_API_KEY=

# Tautulli
FOXHOLE_TAUTULLI_BASE_URL=
FOXHOLE_TAUTULLI_API_KEY=

# Overseerr
FOXHOLE_OVERSEERR_BASE_URL=
FOXHOLE_OVERSEERR_API_KEY=

# Portainer
FOXHOLE_PORTAINER_BASE_URL=
FOXHOLE_PORTAINER_API_TOKEN=
FOXHOLE_PORTAINER_USERNAME=
FOXHOLE_PORTAINER_PASSWORD=

# Pi-hole and Unbound
FOXHOLE_PIHOLE_BASE_URL=
FOXHOLE_PIHOLE_API_TOKEN=
FOXHOLE_UNBOUND_HOST=
FOXHOLE_UNBOUND_PORT=8953

# Network scanning. Lists are JSON-encoded for env, e.g. '["192.168.1.0/24"]'.
FOXHOLE_NETWORK_ALLOWED_SUBNETS=[]
FOXHOLE_NETWORK_KNOWN_MACS=[]
