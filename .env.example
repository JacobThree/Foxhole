# ==========================================
# Foxhole Agent Configuration
# ==========================================

# Core Settings
FOXHOLE_ENVIRONMENT=development
# FOXHOLE_LOG_LEVEL=INFO

# Redis Configuration (Required for Celery/Cache)
FOXHOLE_REDIS_URL=redis://localhost:6379/0

# Durable history (SQLite by default)
FOXHOLE_DATABASE_PATH=/tmp/foxhole/foxhole.db
FOXHOLE_CONFIG_ENV_PATH=.env
FOXHOLE_WIDGET_ENABLED=false
FOXHOLE_WIDGET_TOKEN=
FOXHOLE_EVENT_RETENTION_DAYS=30
FOXHOLE_DIAGNOSTIC_RETENTION_DAYS=90
FOXHOLE_AUDIT_RETENTION_DAYS=365
FOXHOLE_RESOLVED_INCIDENT_RETENTION_DAYS=180
FOXHOLE_CRITICAL_INCIDENT_RETENTION_DAYS=365
# Pinned incidents are retained forever.

# LLM Provider Configuration
FOXHOLE_LLM_PRIMARY_MODEL=agent-primary
FOXHOLE_LLM_PRIMARY_API_KEY=your-primary-api-key-here
# FOXHOLE_LLM_LOCAL_MODEL=agent-local
# FOXHOLE_LLM_LOCAL_API_BASE=http://localhost:11434

# ==========================================
# Modular Integrations (Opt-in)
# ==========================================
# You can also configure these from the Foxhole Dashboard Settings UI!

# Telegram Alerts
FOXHOLE_TELEGRAM_ENABLED=false
FOXHOLE_TELEGRAM_BOT_TOKEN=
FOXHOLE_TELEGRAM_CHAT_ID=

# Proxmox
FOXHOLE_PROXMOX_ENABLED=false
FOXHOLE_PROXMOX_HOST=https://pve.local:8006
FOXHOLE_PROXMOX_TOKEN_ID=root@pam!foxhole
FOXHOLE_PROXMOX_TOKEN_SECRET=

# Docker
FOXHOLE_DOCKER_ENABLED=false
FOXHOLE_DOCKER_SOCKET_PROXY_URL=tcp://socket-proxy:2375

# Portainer
FOXHOLE_PORTAINER_ENABLED=false
FOXHOLE_PORTAINER_BASE_URL=http://localhost:9000
FOXHOLE_PORTAINER_API_TOKEN=

# Media Server (Plex)
FOXHOLE_PLEX_ENABLED=false
FOXHOLE_PLEX_BASE_URL=http://localhost:32400
FOXHOLE_PLEX_TOKEN=
# Optional bounded log read for scheduled Plex DB/transcode diagnostics.
FOXHOLE_PLEX_LOG_PATH=

# Media Management (*Arr)
FOXHOLE_SONARR_ENABLED=false
FOXHOLE_SONARR_BASE_URL=http://localhost:8989
FOXHOLE_SONARR_API_KEY=

FOXHOLE_RADARR_ENABLED=false
FOXHOLE_RADARR_BASE_URL=http://localhost:7878
FOXHOLE_RADARR_API_KEY=

# Observability
FOXHOLE_TAUTULLI_ENABLED=false
FOXHOLE_TAUTULLI_BASE_URL=http://localhost:8181
FOXHOLE_TAUTULLI_API_KEY=

FOXHOLE_OVERSEERR_ENABLED=false
FOXHOLE_OVERSEERR_BASE_URL=http://localhost:5055
FOXHOLE_OVERSEERR_API_KEY=

# Monitoring (Uptime Kuma)
FOXHOLE_UPTIME_KUMA_ENABLED=false
FOXHOLE_UPTIME_KUMA_BASE_URL=http://localhost:3001
FOXHOLE_UPTIME_KUMA_API_TOKEN=

# Reverse Proxy (Caddy)
FOXHOLE_CADDY_ENABLED=false
FOXHOLE_CADDY_CONFIG_PATH=/etc/caddy/Caddyfile
# Optional alternative to reading a Caddyfile.
FOXHOLE_CADDY_ADMIN_API_URL=http://localhost:2019

# Network (Pi-hole)
FOXHOLE_PIHOLE_ENABLED=false
FOXHOLE_PIHOLE_BASE_URL=http://localhost/admin
FOXHOLE_PIHOLE_API_TOKEN=

FOXHOLE_NETWORK_ALLOWED_SUBNETS=192.168.1.0/24
