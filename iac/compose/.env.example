# Copy this file to iac/compose/.env before running docker compose.

FOXHOLE_API_BEARER_TOKEN=change-me
FOXHOLE_CONFIG_ENV_PATH=/config/foxhole.env

# Stage 1 denies all write-class tools.
FOXHOLE_WRITE_STAGE=1
FOXHOLE_WRITE_CONFIRMATION_SECRET=

# LLM aliases. Fill one provider before using /chat with a real model.
FOXHOLE_LLM_PRIMARY_MODEL=agent-primary
FOXHOLE_LLM_PRIMARY_API_KEY=
FOXHOLE_LLM_PRIMARY_API_BASE=
FOXHOLE_LLM_LOCAL_MODEL=agent-local
FOXHOLE_LLM_LOCAL_API_BASE=http://host.docker.internal:11434
FOXHOLE_LLM_VLLM_MODEL=agent-vllm
FOXHOLE_LLM_VLLM_API_BASE=http://host.docker.internal:8001/v1

# Optional homelab integrations.
FOXHOLE_PROXMOX_HOST=
FOXHOLE_PROXMOX_VERIFY_SSL=true
FOXHOLE_PROXMOX_TOKEN_ID=
FOXHOLE_PROXMOX_TOKEN_SECRET=
FOXHOLE_TELEGRAM_BOT_TOKEN=
FOXHOLE_TELEGRAM_CHAT_ID=
FOXHOLE_PLEX_BASE_URL=
FOXHOLE_PLEX_TOKEN=
FOXHOLE_PLEX_LOG_PATH=
FOXHOLE_SONARR_BASE_URL=
FOXHOLE_SONARR_API_KEY=
FOXHOLE_RADARR_BASE_URL=
FOXHOLE_RADARR_API_KEY=
FOXHOLE_TAUTULLI_BASE_URL=
FOXHOLE_TAUTULLI_API_KEY=
FOXHOLE_OVERSEERR_BASE_URL=
FOXHOLE_OVERSEERR_API_KEY=
FOXHOLE_PIHOLE_BASE_URL=
FOXHOLE_PIHOLE_API_TOKEN=
FOXHOLE_UNBOUND_HOST=
FOXHOLE_UNBOUND_PORT=8953
